{
  "name": "ciscript-watcher",
  "version": "2.0.4",
  "description": "Folder watcher that detects new video files, extracts audio, and uploads to transcription server",
  "main": "electron/main.js",
  "author": "AshOfCreativity",
  "scripts": {
    "start": "node index.js",
    "start:electron": "electron electron/main.js",
    "build:win": "electron-builder --win --publish never",
    "dev:ui": "node dev-server.js"
  },
  "license": "MIT",
  "build": {
    "appId": "com.ciscript.watcher",
    "productName": "CIScript Watcher",
    "win": {
      "target": "nsis",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "files": [
      "electron/**/*",
      "lib/**/*",
      "index.js",
      "node_modules/**/*"
    ],
    "extraResources": [],
    "publish": {
      "provider": "github",
      "owner": "AshOfCreativity",
      "repo": "ciscript-watcher"
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "chokidar": "^3.6.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "form-data": "^4.0.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
