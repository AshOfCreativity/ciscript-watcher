{
  "workflows": [
    {
      "name": "Default",
      "watchFolder": "~/Videos",
      "serverUrl": "http://localhost:3000",
      "extensions": [".mp4", ".mkv", ".webm", ".flv", ".mov", ".avi"],
      "approvalMode": "one-stage",
      "deleteWavAfterUpload": true,
      "outputDir": null,
      "archiveDir": null
    }
  ],
  "global": {
    "pollingInterval": 5000,
    "stabilizationDelay": 3000,
    "maxConcurrent": 1,
    "maxRetries": 5,
    "minDiskSpaceGB": 2
  }
}
